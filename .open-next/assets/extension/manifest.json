{
  "manifest_version": 3,
  "name": "NychIQ - YouTube & Social Intelligence",
  "version": "4.0.0",
  "description": "Real-time YouTube, TikTok, Twitter/X & Instagram insights powered by NychIQ AI. Deep scrape data, analyze engagement, predict virality.",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "declarativeNetRequest",
    "alarms",
    "offscreen"
  ],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://youtube.com/*",
    "https://studio.youtube.com/*",
    "https://www.tiktok.com/*",
    "https://tiktok.com/*",
    "https://twitter.com/*",
    "https://x.com/*",
    "https://www.instagram.com/*",
    "https://instagram.com/*",
    "https://nychiq.com/*",
    "https://*.nychiq.com/*",
    "https://*.workers.dev/*"
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "cors_rules",
        "enabled": true,
        "path": "cors_rules.json"
      }
    ]
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/watch*", "https://youtube.com/watch*", "https://www.youtube.com/shorts/*", "https://youtube.com/shorts/*"],
      "js": ["src/content-scripts/utils.js", "src/content-scripts/youtube-watch.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://studio.youtube.com/*"],
      "js": ["src/content-scripts/utils.js", "src/content-scripts/youtube-studio.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.youtube.com/feed/trending*", "https://youtube.com/feed/trending*"],
      "js": ["src/content-scripts/utils.js", "src/content-scripts/youtube-trending.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://twitter.com/*", "https://x.com/*"],
      "js": ["src/content-scripts/utils.js", "src/content-scripts/social-twitter.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.instagram.com/*", "https://instagram.com/*"],
      "js": ["src/content-scripts/utils.js", "src/content-scripts/social-instagram.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.tiktok.com/*", "https://tiktok.com/*"],
      "js": ["src/content-scripts/utils.js", "src/content-scripts/social-tiktok.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "src/background/background.js",
    "type": "module"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' https://cdn.jsdelivr.net; object-src 'self'"
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
